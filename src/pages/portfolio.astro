---
import PortalLayout from '../layouts/PortalLayout.astro';
import { projects, socialLinks } from '../data/portal';
---
<PortalLayout title="Portfolio · NON/LAB" description="Selected builds, homelab experiments and software projects by NON.">
	<section class="portfolio-intro">
		<p class="eyebrow">PORTFOLIO · DEVELOPER / HOMELAB EXPLORER</p>
		<div class="portfolio-title-row">
			<h1>Things I build<br /><span>to learn what’s next.</span></h1>
			<p>นักพัฒนาจากประเทศไทย สนุกกับ Python, Next.js, Go, infrastructure, multimedia และทุกไอเดียที่ทำให้ homelab มีของใหม่ให้ลอง</p>
		</div>
		<div class="availability-line"><span class="pulse-dot"></span><span>Currently exploring AI agents, self-hosting and interfaces that feel alive.</span></div>
	</section>

	<section class="section-block portfolio-projects" aria-labelledby="work-title">
		<div class="section-heading">
			<div><p class="section-index">01 / SELECTED WORK</p><h2 id="work-title">Projects & experiments</h2></div>
			<p class="section-note">เนื้อหาตั้งต้นแก้ไขได้ที่ <code>src/data/portal.ts</code></p>
		</div>
		<div class="project-list">
			{projects.map((project) => (
				<a href={project.href} target="_blank" rel="noreferrer" data-command={project.title} data-command-meta={project.type}>
					<div class="project-index">{project.index}</div>
					<div class="project-main"><p>{project.type}</p><h3>{project.title}</h3><span>{project.description}</span></div>
					<div class="project-tags">{project.tags.map((tag) => <span>{tag}</span>)}</div>
					<div class="project-arrow" aria-hidden="true">↗</div>
				</a>
			))}
		</div>
	</section>

	<section class="profile-grid section-block">
		<article class="profile-panel profile-about">
			<p class="section-index">02 / ABOUT</p>
			<h2>Hello, I’m NON.</h2>
			<p>ผมชอบเปลี่ยนคำถามว่า “ถ้าลองทำแบบนี้ล่ะ?” ให้กลายเป็นโปรเจกต์จริง ตั้งแต่เว็บและ backend ไปจนถึง VM, Raspberry Pi, automation และ media experiments</p>
			<p>นอกเวลาหน้าจอ ผมสนใจอวกาศ จักรวาล และดูแลแมวสองตัวชื่อ <strong>รถถัง</strong> กับ <strong>รถทัวร์</strong></p>
		</article>
		<article class="profile-panel stack-panel">
			<p class="section-index">STACK / INTERESTS</p>
			<ul>
				<li><span>Languages</span><strong>Python · Go · TypeScript</strong></li>
				<li><span>Web</span><strong>Next.js · Astro · APIs</strong></li>
				<li><span>Lab</span><strong>Proxmox · Linux · Raspberry Pi</strong></li>
				<li><span>Curiosity</span><strong>AI · Space · Multimedia</strong></li>
			</ul>
		</article>
	</section>

	<section class="section-block connect-section">
		<div><p class="section-index">03 / CONNECT</p><h2>Find me on the internet.</h2></div>
		<div class="social-list">
			{socialLinks.map((link) => (
				<a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer" data-command={link.label} data-command-meta={link.handle}>
					<span>{link.label}</span><small>{link.handle}</small><i aria-hidden="true">↗</i>
				</a>
			))}
		</div>
	</section>
</PortalLayout>
