---
import { getCollection } from 'astro:content';
import PortalLayout from '../layouts/PortalLayout.astro';
import { services } from '../data/portal';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const latestPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<PortalLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="portal-hero" aria-labelledby="portal-title">
		<div class="hero-copy">
			<p class="eyebrow"><span class="pulse-dot"></span> PERSONAL CONTROL PLANE · <span data-local-time>--:--</span></p>
			<h1 id="portal-title">Build things.<br /><span>Run everything.</span></h1>
			<p class="hero-lede">ประตูหน้าเข้าสู่ homelab, AI tools และงานทดลองของ NON — รวมทุกอย่างที่อยากเปิดใช้ไว้ในพื้นที่เดียว</p>
			<div class="hero-actions">
				<a class="button primary" href="#services">เปิด service</a>
				<a class="button secondary" href="/portfolio">ดูผลงาน <span aria-hidden="true">↗</span></a>
			</div>
		</div>
		<aside class="hero-console" aria-label="Portal quick guide">
			<div class="console-bar"><span>quick-start.sh</span><span class="console-lights">● ● ●</span></div>
			<div class="console-body">
				<p><span class="prompt">~</span> portal status</p>
				<div class="console-row"><span>services</span><strong>{String(services.length).padStart(2, '0')}</strong></div>
				<div class="console-row"><span>workspace</span><strong>INONTZ</strong></div>
				<div class="console-row"><span>mode</span><strong>CURIOUS</strong></div>
				<p class="console-hint"><span class="prompt">›</span> กด <kbd>⌘ K</kbd> เพื่อไปทุกที่แบบเร็ว ๆ</p>
			</div>
		</aside>
	</section>

	<section class="section-block" id="services" aria-labelledby="services-title">
		<div class="section-heading">
			<div>
				<p class="section-index">01 / SERVICES</p>
				<h2 id="services-title">Launch deck</h2>
			</div>
			<div class="service-tools">
						<label class="service-search">
							<span aria-hidden="true">⌕</span>
							<input type="search" placeholder="Filter services" aria-label="Search services" data-service-search />
						</label>
						<button class="add-service" type="button" data-add-service>＋ Add subdomain</button>
					</div>
				</div>
				<div class="filter-row" role="group" aria-label="Filter service category">
					<button class="filter-chip active" type="button" data-filter="All" aria-pressed="true">All</button>
					<button class="filter-chip" type="button" data-filter="Infra" aria-pressed="false">Infra</button>
					<button class="filter-chip" type="button" data-filter="AI" aria-pressed="false">AI</button>
					<button class="filter-chip" type="button" data-filter="Dev" aria-pressed="false">Dev</button>
				</div>
		<div class="service-list" data-service-list>
			{services.map((service, index) => (
				<a
					class:list={['service-item', { featured: service.featured }]}
					href={service.url}
					target="_blank"
					rel="noreferrer"
					style={`--service-accent: ${service.accent}`}
					data-category={service.category}
					data-service-name={`${service.name} ${service.host}`}
					data-command={service.name}
					data-command-meta={service.host}
				>
					<span class="service-number">{String(index + 1).padStart(2, '0')}</span>
					<span class="service-mark" aria-hidden="true">{service.mark}</span>
					<span class="service-copy"><strong>{service.name}</strong><small>{service.description}</small></span>
					<span class="service-host">{service.host}</span>
					<span class="service-category">{service.category}</span>
					<span class="service-arrow" aria-hidden="true">↗</span>
				</a>
			))}
		</div>
		<p class="empty-services" data-service-empty hidden>ไม่มี service ที่ตรงกับคำค้น</p>
	</section>

	<section class="section-block" id="playground" aria-labelledby="playground-title">
		<div class="section-heading">
			<div>
				<p class="section-index">02 / PLAYGROUND</p>
				<h2 id="playground-title">พักสมองสักครู่</h2>
			</div>
			<p class="section-note">เครื่องมือเล็ก ๆ ที่ทำงานใน browser และจำค่าด้วย localStorage</p>
		</div>
		<div class="play-grid">
			<article class="play-card focus-card">
				<div class="play-card-head"><span>FOCUS_25</span><span data-focus-state>READY</span></div>
				<div class="timer-ring" data-timer-ring style="--progress: 0deg">
					<div><strong data-focus-time>25:00</strong><small>minutes</small></div>
				</div>
				<div class="play-actions">
					<button type="button" class="button primary compact" data-focus-toggle>Start focus</button>
					<button type="button" class="button secondary compact" data-focus-reset>Reset</button>
				</div>
			</article>

			<article class="play-card signal-card">
				<div class="play-card-head"><span>SIGNAL_HUNT</span><span>SCORE <b data-signal-score>00</b></span></div>
				<div class="signal-arena" data-signal-arena>
					<div class="orbit orbit-one"></div><div class="orbit orbit-two"></div>
					<button class="signal-node" type="button" data-signal-node aria-label="Catch signal" hidden></button>
					<div class="signal-intro" data-signal-intro><strong>จับสัญญาณที่หลุดวงโคจร</strong><small>มีเวลา 20 วินาที</small></div>
				</div>
				<button type="button" class="button secondary compact wide" data-signal-start>Start hunt</button>
			</article>

			<article class="play-card cosmic-card">
				<div class="play-card-head"><span>COSMIC_PACKET</span><span data-fact-count>01 / 05</span></div>
				<div class="cosmic-symbol" aria-hidden="true">✦</div>
				<blockquote data-cosmic-fact>แสงจากดวงอาทิตย์ใช้เวลาประมาณ 8 นาที 20 วินาทีเดินทางมาถึงโลก</blockquote>
				<button type="button" class="text-button" data-cosmic-next>รับสัญญาณถัดไป →</button>
			</article>
		</div>
	</section>

	<section class="section-block notes-preview" aria-labelledby="notes-title">
		<div class="section-heading">
			<div><p class="section-index">03 / NOTES</p><h2 id="notes-title">Recent transmissions</h2></div>
			<a class="text-link" href="/blog">อ่านทั้งหมด →</a>
		</div>
		<div class="notes-list">
			{latestPosts.map((post, index) => (
				<a href={`/blog/${post.id}/`} data-command={post.data.title} data-command-meta="Note">
					<span>{String(index + 1).padStart(2, '0')}</span>
					<strong>{post.data.title}</strong>
					<time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
					<i aria-hidden="true">↗</i>
				</a>
			))}
		</div>
	</section>

	<dialog class="add-dialog" data-add-dialog>
		<form method="dialog" data-add-form>
			<div class="modal-heading"><div><p class="section-index">LOCAL SHORTCUT</p><h2>Add subdomain</h2></div><button value="cancel" aria-label="Close">×</button></div>
			<p>เพิ่ม shortcut เฉพาะ browser นี้ ข้อมูลจะถูกเก็บใน localStorage</p>
			<label>ชื่อ service<input required name="name" maxlength="30" placeholder="Grafana" /></label>
			<label>Subdomain หรือ URL<input required name="host" placeholder="grafana.inontz.me" /></label>
			<label>หมวดหมู่<select name="category"><option>Infra</option><option>AI</option><option>Dev</option></select></label>
			<div class="modal-actions"><button class="button secondary" type="button" value="cancel">Cancel</button><button class="button primary" type="submit" value="default" data-add-save>Save shortcut</button></div>
		</form>
	</dialog>
</PortalLayout>

<script>
	const localTime = document.querySelector('[data-local-time]');
	const updateClock = () => { if (localTime) localTime.textContent = new Intl.DateTimeFormat('th-TH', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false }).format(new Date()); };
	updateClock(); setInterval(updateClock, 1000);

	const list = document.querySelector('[data-service-list]');
	const search = document.querySelector('[data-service-search]');
	const empty = document.querySelector('[data-service-empty]');
	let activeFilter = 'All';
	const filterServices = () => {
		const query = search?.value.toLowerCase().trim() || '';
		let visible = 0;
		list?.querySelectorAll('[data-service-name]').forEach((item) => {
			const matchesFilter = activeFilter === 'All' || item.dataset.category === activeFilter;
			const matchesSearch = item.dataset.serviceName.toLowerCase().includes(query);
			item.hidden = !(matchesFilter && matchesSearch); if (!item.hidden) visible++;
		});
		if (empty) empty.hidden = visible !== 0;
	};
	search?.addEventListener('input', filterServices);
	document.querySelectorAll('[data-filter]').forEach((button) => button.addEventListener('click', () => {
			activeFilter = button.dataset.filter; document.querySelectorAll('[data-filter]').forEach((item) => { item.classList.toggle('active', item === button); item.setAttribute('aria-pressed', String(item === button)); }); filterServices();
		}));

	const addDialog = document.querySelector('[data-add-dialog]');
	const addForm = document.querySelector('[data-add-form]');
	const storageKey = 'inontz-custom-services';
	const getCustom = () => { try { const v = JSON.parse(localStorage.getItem(storageKey) || '[]'); return Array.isArray(v) ? v : []; } catch { return []; } };
	const isSafeUrl = (url) => { try { const u = new URL(url); return u.protocol === 'http:' || u.protocol === 'https:'; } catch { return false; } };
	const renderCustom = () => {
			list?.querySelectorAll('[data-custom-service]').forEach((item) => item.remove());
			getCustom().forEach((service, index) => {
				if (!isSafeUrl(service.url)) return;
				const anchor = document.createElement('a'); anchor.className = 'service-item custom-service'; anchor.href = service.url; anchor.target = '_blank'; anchor.rel = 'noreferrer'; anchor.dataset.category = service.category; anchor.dataset.serviceName = `${service.name} ${service.host}`; anchor.dataset.command = service.name; anchor.dataset.commandMeta = service.host; anchor.dataset.customService = 'true'; anchor.style.setProperty('--service-accent', '#59d5c8');
				const values = [['span', 'service-number', `L${index + 1}`], ['span', 'service-mark', '+'], ['span', 'service-host', service.host], ['span', 'service-category', service.category], ['span', 'service-arrow', '↗']];
				values.forEach(([tag, className, text]) => { const el = document.createElement(tag); el.className = className; el.textContent = text; anchor.append(el); });
				const copy = document.createElement('span'); copy.className = 'service-copy'; const strong = document.createElement('strong'); strong.textContent = service.name; const small = document.createElement('small'); small.textContent = 'Custom shortcut · คลิกขวาหรือเพิ่มใหม่เพื่อแก้ไข'; copy.append(strong, small); anchor.insertBefore(copy, anchor.children[2]); list?.append(anchor);
			}); filterServices();
		};
	renderCustom();
		addForm?.addEventListener('submit', (event) => {
			event.preventDefault();
			if (!addForm?.reportValidity()) return;
			const data = new FormData(addForm); const rawHost = String(data.get('host') || '').trim();
			let url; try { url = new URL(/^https?:\/\//i.test(rawHost) ? rawHost : `https://${rawHost}`); } catch { addForm.querySelector('[name="host"]')?.setCustomValidity('กรุณาใส่ subdomain หรือ URL ให้ถูกต้อง'); addForm.reportValidity(); return; }
			const items = getCustom(); items.push({ name: String(data.get('name')), host: url.host, url: url.href, category: String(data.get('category')) }); localStorage.setItem(storageKey, JSON.stringify(items)); addForm.reset(); renderCustom(); addDialog.close();
		});
		addForm?.querySelector('[name="host"]')?.addEventListener('input', (event) => event.currentTarget.setCustomValidity(''));
		addDialog?.addEventListener('click', (event) => { if (event.target === addDialog) addDialog.close(); });

	const defaultTitle = document.title; let focusRemaining = 1500; let focusEnd = 0; let focusInterval;
	const getStorage = (key, fallback) => { try { const v = localStorage.getItem(key); return v !== null ? v : fallback; } catch { return fallback; } };
	const setStorage = (key, value) => { try { localStorage.setItem(key, value); } catch {} };
	const removeStorage = (key) => { try { localStorage.removeItem(key); } catch {} };
	const renderFocus = () => { const minutes = Math.floor(focusRemaining / 60); const seconds = focusRemaining % 60; focusTime.textContent = `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`; focusRing.style.setProperty('--progress', `${(1 - focusRemaining / 1500) * 360}deg`); };
	const tickFocus = () => { focusRemaining = Math.max(0, Math.ceil((focusEnd - Date.now()) / 1000)); renderFocus(); if (focusRemaining <= 0) { clearInterval(focusInterval); focusEnd = 0; focusState.textContent = 'DONE'; focusToggle.textContent = 'Start again'; removeStorage('inontz-focus-end'); document.title = 'Focus complete · NON/LAB'; } };
	focusToggle?.addEventListener('click', () => { if (focusEnd > Date.now()) { clearInterval(focusInterval); focusRemaining = Math.ceil((focusEnd - Date.now()) / 1000); focusEnd = 0; focusState.textContent = 'PAUSED'; focusToggle.textContent = 'Resume'; removeStorage('inontz-focus-end'); return; } if (focusRemaining <= 0) focusRemaining = 1500; document.title = defaultTitle; focusEnd = Date.now() + focusRemaining * 1000; setStorage('inontz-focus-end', String(focusEnd)); focusState.textContent = 'FOCUSING'; focusToggle.textContent = 'Pause'; tickFocus(); focusInterval = setInterval(tickFocus, 1000); });
	const savedEnd = Number(getStorage('inontz-focus-end', '0')); if (savedEnd > Date.now()) { focusEnd = savedEnd; focusState.textContent = 'FOCUSING'; focusToggle.textContent = 'Pause'; tickFocus(); focusInterval = setInterval(tickFocus, 1000); } else renderFocus();

	const arena = document.querySelector('[data-signal-arena]'); const node = document.querySelector('[data-signal-node]'); const signalScore = document.querySelector('[data-signal-score]'); const signalIntro = document.querySelector('[data-signal-intro]'); const signalStart = document.querySelector('[data-signal-start]'); let score = 0; let huntTimer;
	const moveSignal = () => { node.style.left = `${8 + Math.random() * 78}%`; node.style.top = `${10 + Math.random() * 70}%`; };
	node?.addEventListener('click', () => { score++; signalScore.textContent = String(score).padStart(2, '0'); moveSignal(); });
	signalStart?.addEventListener('click', () => { clearTimeout(huntTimer); score = 0; signalScore.textContent = '00'; signalIntro.hidden = true; node.hidden = false; signalStart.disabled = true; signalStart.textContent = 'Hunting · 20s'; moveSignal(); huntTimer = setTimeout(() => { node.hidden = true; signalIntro.hidden = false; signalIntro.querySelector('strong').textContent = `รับสัญญาณได้ ${score} ครั้ง`; signalIntro.querySelector('small').textContent = score > 12 ? 'มือไวเกินมนุษย์แล้ว' : 'ลองทำลายสถิติอีกครั้ง'; signalStart.disabled = false; signalStart.textContent = 'Hunt again'; localStorage.setItem('inontz-signal-high', String(Math.max(score, Number(localStorage.getItem('inontz-signal-high') || 0)))); }, 20000); });

	const facts = ['แสงจากดวงอาทิตย์ใช้เวลาประมาณ 8 นาที 20 วินาทีเดินทางมาถึงโลก', 'หนึ่งวันบนดาวศุกร์ยาวกว่าหนึ่งปีของดาวศุกร์เอง', 'ดาวนิวตรอนหนึ่งช้อนชาอาจมีมวลหลายพันล้านตันบนโลก', 'ทางช้างเผือกมีเส้นผ่านศูนย์กลางประมาณหนึ่งแสนปีแสง', 'รอยเท้านักบินอวกาศบนดวงจันทร์อาจคงอยู่หลายล้านปี เพราะแทบไม่มีลมหรือฝน']; let factIndex = 0;
	document.querySelector('[data-cosmic-next]')?.addEventListener('click', () => { factIndex = (factIndex + 1) % facts.length; document.querySelector('[data-cosmic-fact]').textContent = facts[factIndex]; document.querySelector('[data-fact-count]').textContent = `${String(factIndex + 1).padStart(2, '0')} / ${String(facts.length).padStart(2, '0')}`; });
</script>
